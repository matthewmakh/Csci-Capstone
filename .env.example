# Required: Anthropic API key for the Triage Agent (Claude Opus 4.7).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: NVD API key boosts rate limits from 5 req/30s to 50 req/30s.
# Request one at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Optional: override paths
VULN_PLATFORM_DB=findings.db
VULN_PLATFORM_AUDIT_LOG=audit.jsonl
